# Server Configuration
PORT=5000
NODE_ENV=production

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/prajashakthi

# JWT Secret (IMPORTANT: Generate a secure random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Allowed Origins (comma-separated, no spaces)
# Add your production domains here
CORS_ORIGIN=http://192.168.4.7,http://203.115.31.132,http://cdc_data.prajashakthi.gov.lk,https://cdc_data.prajashakthi.gov.lk

# Email Configuration (Optional - for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Session Secret (Optional)
SESSION_SECRET=your-session-secret-change-this
